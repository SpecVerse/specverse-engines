  NotificationService_sendTrackingInfo -->|"publishes"| event_CustomerNotified
  NotificationService_sendCancellationNotice -->|"publishes"| event_CustomerNotified
  event_OrderCreated -.->|"subscribes"| NotificationService_entry
  event_PaymentProcessed -.->|"subscribes"| NotificationService_entry
  event_PaymentFailed -.->|"subscribes"| NotificationService_entry
  event_InventoryReserved -.->|"subscribes"| NotificationService_entry
  event_InsufficientStock -.->|"subscribes"| NotificationService_entry
  event_ShipmentPrepared -.->|"subscribes"| NotificationService_entry
  event_OrderShipped -.->|"subscribes"| NotificationService_entry
  event_OrderCancelled -.->|"subscribes"| NotificationService_entry
  AnalyticsService_trackOrderCreated -->|"publishes"| event_AnalyticsEventRecorded
  AnalyticsService_trackPaymentSuccess -->|"publishes"| event_AnalyticsEventRecorded
  AnalyticsService_trackPaymentFailure -->|"publishes"| event_AnalyticsEventRecorded
  AnalyticsService_trackOrderShipped -->|"publishes"| event_AnalyticsEventRecorded
  event_OrderCreated -.->|"subscribes"| AnalyticsService_entry
  event_PaymentProcessed -.->|"subscribes"| AnalyticsService_entry
  event_PaymentFailed -.->|"subscribes"| AnalyticsService_entry
  event_OrderShipped -.->|"subscribes"| AnalyticsService_entry

