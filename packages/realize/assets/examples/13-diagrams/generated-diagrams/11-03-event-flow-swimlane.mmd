graph LR
  %% Event Flow Architecture

  subgraph swimlane_OrderController["OrderController (controller)"]
    direction TB
    OrderController_entry("OrderController
controller")
    OrderController_create("create")
    OrderController_update("update")
    OrderController_cancelOrder("cancelOrder")
  end

  subgraph swimlane_PaymentService["PaymentService (service)"]
    direction TB
    PaymentService_entry("PaymentService
service")
    PaymentService_processPayment("processPayment")
    PaymentService_retryPayment("retryPayment")
    PaymentService_refundPayment("refundPayment")
  end

  subgraph swimlane_InventoryService["InventoryService (service)"]
    direction TB
    InventoryService_entry("InventoryService
service")
    InventoryService_reserveItems("reserveItems")
    InventoryService_releaseItems("releaseItems")
    InventoryService_allocateItems("allocateItems")
  end

  subgraph swimlane_FulfillmentService["FulfillmentService (service)"]
    direction TB
    FulfillmentService_entry("FulfillmentService
service")
    FulfillmentService_prepareShipment("prepareShipment")
    FulfillmentService_shipOrder("shipOrder")
    FulfillmentService_cancelShipment("cancelShipment")
  end

  subgraph swimlane_NotificationService["NotificationService (service)"]
    direction TB
    NotificationService_entry("NotificationService
service")
    NotificationService_sendOrderConfirmation("sendOrderConfirmation")
    NotificationService_sendPaymentConfirmation("sendPaymentConfirmation")
    NotificationService_sendPaymentFailureNotice("sendPaymentFailureNotice")
    NotificationService_sendInventoryConfirmation("sendInventoryConfirmation")
    NotificationService_sendOutOfStockNotice("sendOutOfStockNotice")
    NotificationService_sendShipmentNotification("sendShipmentNotification")
    NotificationService_sendTrackingInfo("sendTrackingInfo")
    NotificationService_sendCancellationNotice("sendCancellationNotice")
  end

  subgraph swimlane_AnalyticsService["AnalyticsService (service)"]
    direction TB
    AnalyticsService_entry("AnalyticsService
service")
    AnalyticsService_trackOrderCreated("trackOrderCreated")
    AnalyticsService_trackPaymentSuccess("trackPaymentSuccess")
    AnalyticsService_trackPaymentFailure("trackPaymentFailure")
    AnalyticsService_trackOrderShipped("trackOrderShipped")
  end

  event_OrderCreated{{"OrderCreated"}}
  event_OrderUpdated{{"OrderUpdated"}}
  event_OrderCancelled{{"OrderCancelled"}}
  event_PaymentProcessed{{"PaymentProcessed"}}
  event_PaymentFailed{{"PaymentFailed"}}
  event_PaymentRetryInitiated{{"PaymentRetryInitiated"}}
  event_PaymentRefunded{{"PaymentRefunded"}}
  event_InventoryReserved{{"InventoryReserved"}}
