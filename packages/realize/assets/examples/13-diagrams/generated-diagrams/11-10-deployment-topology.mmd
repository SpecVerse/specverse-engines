graph TB
  %% Deployment Topology

  subgraph communication_channels["Communication Channels"]
    direction LR
    eventBus(["eventBus<br>📡 pubsub<br>🌐 global<br>📋 1 capabilities"])
  end

  subgraph controller_instances["Controller Instances"]
    direction LR
    apiServer(["🎮 apiServer<br>📦 MinimalSyntaxReference<br>🏷️ api<br>⚖️ scale: 1"])
  end

  eventBus_caps("all (*)")
  apiServer_adv("📢 Advertises:<br>behaviors.*<br>actions.*<br>+1 more")
