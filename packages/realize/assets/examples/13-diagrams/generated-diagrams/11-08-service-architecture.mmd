  %% System Architecture

  subgraph services_layer["🔧 SERVICE LAYER"]
    direction LR
    AccountService("AccountService
Operations: openAccount, closeAccount, freezeAccount, unfreezeAccount, getBalance, updateBalance, transferFunds")
    TransactionService("TransactionService
Operations: createTransaction, processTransaction, reverseTransaction, processTransfer, validateTransaction
Subscribes: FundsTransferred")
    FraudDetectionService("FraudDetectionService
Operations: analyzeTransaction, analyzeNewAccount, calculateRiskScore, checkVelocity, checkLocation
Subscribes: TransactionCreated, AccountOpened")
    NotificationService("NotificationService
Operations: sendTransactionNotification, sendFraudAlert, sendAccountAlert, sendBalanceNotification, sendEmail, sendSMS
Subscribes: TransactionProcessed, FraudAlertCreated, AccountFrozen, BalanceUpdated")
    AuditService("AuditService
Operations: logAccountEvent, logTransactionEvent, logFraudEvent, logUserAction, queryAuditLog
Subscribes: AccountOpened, AccountClosed, TransactionProcessed, FraudAlertCreated")
    ComplianceService("ComplianceService
Operations: checkCompliance, verifyKYC, reportSuspiciousActivity, checkSanctions
Subscribes: TransactionProcessed, AccountOpened")
    ReportingService("ReportingService
Operations: updateMetrics, updateAuditMetrics, generateDailyReport, generateMonthlyReport, getTransactionStats
Subscribes: TransactionProcessed, AuditLogCreated")
    BalanceReconciliationService("BalanceReconciliationService
Operations: reconcileBalance, detectDiscrepancies, fixDiscrepancy, scheduledReconciliation
Subscribes: TransactionProcessed, TransactionReversed")
  end

