{
  "$id": "specverse://entities/services",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Service-specific schema definitions",
  "$defs": {
    "ServicesSection": {
      "type": "object",
      "patternProperties": {
        "^[A-Z][A-Za-z0-9_]*$": {
          "type": "object",
          "properties": {
            "description": {
              "type": "string"
            },
            "subscribes_to": {
              "$ref": "#/$defs/SubscriptionsPattern"
            },
            "operations": {
              "type": "object",
              "patternProperties": {
                "^[a-z][a-zA-Z0-9_]*$": {
                  "$ref": "#/$defs/ExecutableProperties"
                }
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
