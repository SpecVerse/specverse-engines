{
  "ruleFileType": "configuration",
  "version": "v3.4.0",
  "category": "component-mappings",
  "description": "Component type mappings for automatic CRUD view generation with 49 atomic component types",
  "mappings": {
    "description": "Maps model attributes and relationships to the 49 atomic UI component types",
    "attributes": [
      {
        "attributeType": "String",
        "constraints": { "has": "values" },
        "componentType": "select",
        "description": "String with enum values → select dropdown"
      },
      {
        "attributeType": "String",
        "constraints": { "minLength": ">100" },
        "componentType": "textarea",
        "description": "Long string → textarea"
      },
      {
        "attributeType": "String",
        "default": true,
        "componentType": "input",
        "description": "Default string → text input"
      },
      {
        "attributeType": "Text",
        "componentType": "textarea",
        "description": "Text type → textarea"
      },
      {
        "attributeType": "Integer",
        "componentType": "input",
        "properties": { "type": "number" },
        "description": "Integer → number input"
      },
      {
        "attributeType": "Float",
        "componentType": "input",
        "properties": { "type": "number", "step": "0.01" },
        "description": "Float → decimal number input"
      },
      {
        "attributeType": "Boolean",
        "componentType": "switch",
        "description": "Boolean → toggle switch"
      },
      {
        "attributeType": "DateTime",
        "componentType": "datepicker",
        "properties": { "showTime": true },
        "description": "DateTime → datepicker with time"
      },
      {
        "attributeType": "Date",
        "componentType": "datepicker",
        "description": "Date → datepicker"
      },
      {
        "attributeType": "Time",
        "componentType": "timepicker",
        "description": "Time → timepicker"
      },
      {
        "attributeType": "Money",
        "componentType": "input",
        "properties": { "type": "number", "prefix": "$", "step": "0.01" },
        "description": "Money → currency input"
      },
      {
        "attributeType": "Email",
        "componentType": "input",
        "properties": { "type": "email" },
        "description": "Email → email input"
      },
      {
        "attributeType": "URL",
        "componentType": "input",
        "properties": { "type": "url" },
        "description": "URL → url input"
      },
      {
        "attributeType": "PhoneNumber",
        "componentType": "input",
        "properties": { "type": "tel" },
        "description": "PhoneNumber → tel input"
      },
      {
        "attributeType": "JSON",
        "componentType": "code-editor",
        "properties": { "language": "json" },
        "description": "JSON → code editor"
      },
      {
        "attributeType": "UUID",
        "componentType": "input",
        "properties": { "readonly": true },
        "description": "UUID → readonly text input"
      }
    ],
    "relationships": [
      {
        "relationshipType": "belongsTo",
        "componentType": "autocomplete",
        "properties": { "searchable": true },
        "description": "belongsTo → autocomplete (entity selector)"
      },
      {
        "relationshipType": "hasOne",
        "componentType": "card",
        "properties": { "nested": true },
        "description": "hasOne → nested card"
      },
      {
        "relationshipType": "hasMany",
        "componentType": "list",
        "properties": { "expandable": true },
        "description": "hasMany → expandable list"
      },
      {
        "relationshipType": "manyToMany",
        "componentType": "transfer",
        "properties": { "searchable": true },
        "description": "manyToMany → transfer list (dual list selector)"
      }
    ],
    "listViewPattern": {
      "searchBar": {
        "type": "input",
        "properties": { "placeholder": "Search...", "debounce": 300 }
      },
      "filterPanel": {
        "type": "filterPanel",
        "properties": { "collapsible": true }
      },
      "table": {
        "type": "table",
        "properties": { "pagination": true, "sortable": true, "selectable": true }
      },
      "actionToolbar": {
        "type": "button-group",
        "properties": { "actions": ["create", "delete", "export"] }
      }
    },
    "detailViewPattern": {
      "header": {
        "type": "header",
        "properties": { "showBackButton": true }
      },
      "card": {
        "type": "card",
        "properties": { "variant": "detailed" }
      },
      "tabs": {
        "type": "tabs",
        "properties": { "lazy": true }
      },
      "actions": {
        "type": "button-group",
        "properties": { "actions": ["edit", "delete"] }
      }
    },
    "formViewPattern": {
      "header": {
        "type": "header",
        "properties": { "showBackButton": true }
      },
      "form": {
        "type": "form",
        "properties": { "layout": "vertical", "validation": "realtime" }
      },
      "actions": {
        "type": "button-group",
        "properties": { "actions": ["save", "cancel"] }
      }
    }
  }
}
