{
  "$id": "specverse://entities/events",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Event-specific schema definitions",
  "$defs": {
    "EventsSection": {
      "type": "object",
      "patternProperties": {
        "^[A-Z][A-Za-z0-9_]*$": {
          "type": "object",
          "properties": {
            "description": {
              "type": "string"
            },
            "attributes": {
              "$ref": "#/$defs/AttributesSection"
            },
            "version": {
              "type": "integer",
              "minimum": 1,
              "default": 1,
              "description": "Event schema version number"
            },
            "previousVersions": {
              "type": "array",
              "description": "Previous schema versions for compatibility tracking",
              "items": {
                "type": "object",
                "properties": {
                  "version": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "compatibility": {
                    "type": "string",
                    "enum": [
                      "backward",
                      "forward",
                      "full",
                      "none"
                    ],
                    "default": "none",
                    "description": "Compatibility mode with current version"
                  },
                  "deprecated": {
                    "type": "boolean",
                    "default": false
                  },
                  "deprecationMessage": {
                    "type": "string"
                  }
                },
                "required": [
                  "version"
                ],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
