{
  "$id": "specverse://schema/instance-factories",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Instance factory definitions and related policies",
  "$defs": {
    "InstanceFactoryDefinition": {
      "type": "object",
      "description": "Instance factory definition - reusable technology specification for deployment instances",
      "required": [
        "name",
        "version",
        "category",
        "capabilities",
        "technology",
        "codeTemplates"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9]*$",
          "description": "Unique name (e.g., 'FastifyPrismaAPI', 'PostgreSQL15')"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9-]+)?(\\+[A-Za-z0-9-]+)?$",
          "description": "Semantic version"
        },
        "category": {
          "type": "string",
          "enum": [
            "controller",
            "service",
            "view",
            "storage",
            "security",
            "infrastructure",
            "monitoring",
            "communication",
            "scaffolding",
            "application",
            "cli"
          ],
          "description": "Which deployment instance category this implements"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description"
        },
        "compatibility": {
          "type": "object",
          "description": "Version compatibility requirements",
          "required": [
            "specverse"
          ],
          "properties": {
            "specverse": {
              "type": "string",
              "description": "SpecVerse version range (semver)"
            },
            "node": {
              "type": "string",
              "description": "Node.js version requirement"
            }
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "capabilities": {
          "type": "object",
          "description": "What this instance provides and requires",
          "required": [
            "provides"
          ],
          "properties": {
            "provides": {
              "type": "array",
              "description": "Capabilities this instance type provides",
              "items": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9]*\\.[a-z][a-z0-9]*(\\.[a-z*][a-z0-9*]*)*$"
              },
              "minItems": 1
            },
            "requires": {
              "type": "array",
              "description": "Capabilities this instance type requires",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "technology": {
          "type": "object",
          "description": "Technology stack information",
          "required": [
            "runtime",
            "language"
          ],
          "properties": {
            "runtime": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9-]+$",
              "description": "Runtime environment identifier. Standard runtimes: node, deno, bun, python, rust, go, browser. See SpecVerse Registry for complete list.",
              "examples": [
                "node",
                "deno",
                "bun"
              ],
              "$comment": "Validation: Linter checks against SpecVerse runtime registry"
            },
            "language": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9-]+$",
              "description": "Programming language identifier (kebab-case). Standard languages: typescript, javascript, python, rust, go, java, csharp, php, ruby, kotlin, swift. See SpecVerse Registry for complete list.",
              "examples": [
                "typescript",
                "python",
                "rust"
              ],
              "$comment": "Validation: Linter checks against SpecVerse language registry"
            },
            "framework": {
              "type": "string",
              "description": "Framework name (e.g., 'fastify', 'express', 'nextjs')"
            },
            "database": {
              "type": "string",
              "description": "Database system (e.g., 'postgresql', 'mongodb')"
            },
            "version": {
              "type": "string",
              "description": "Technology version"
            }
          },
          "additionalProperties": {
            "type": "string",
            "description": "Additional tech-specific fields (e.g., orm, validation, cache)"
          }
        },
        "dependencies": {
          "type": "object",
          "description": "Package dependencies",
          "properties": {
            "runtime": {
              "type": "array",
              "description": "Runtime dependencies",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "version"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "version": {
                    "type": "string"
                  },
                  "optional": {
                    "type": "boolean"
                  }
                }
              }
            },
            "dev": {
              "type": "array",
              "description": "Development dependencies",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "version"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "version": {
                    "type": "string"
                  }
                }
              }
            },
            "peer": {
              "type": "array",
              "description": "Peer dependencies",
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "version"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "version": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "codeTemplates": {
          "type": "object",
          "description": "Code generation templates",
          "additionalProperties": {
            "type": "object",
            "required": [
              "engine",
              "outputPattern"
            ],
            "properties": {
              "engine": {
                "type": "string",
                "description": "Template engine to use",
                "enum": [
                  "typescript",
                  "handlebars",
                  "ai"
                ]
              },
              "template": {
                "type": "string",
                "description": "Template content or path (for handlebars)"
              },
              "generator": {
                "type": "string",
                "description": "Path to generator function (for typescript)"
              },
              "prompt": {
                "type": "string",
                "description": "Generation prompt (for AI)"
              },
              "outputPattern": {
                "type": "string",
                "description": "Output file path pattern with variables"
              },
              "validators": {
                "type": "array",
                "description": "Validation function paths",
                "items": {
                  "type": "string"
                }
              },
              "postProcessors": {
                "type": "array",
                "description": "Post-processing function paths",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "minProperties": 1
        },
        "configuration": {
          "type": "object",
          "description": "Default configuration (tech-specific structure)",
          "additionalProperties": true
        },
        "configurationSchema": {
          "description": "Optional JSON Schema to validate configuration overrides",
          "oneOf": [
            {
              "type": "object",
              "description": "Inline JSON Schema"
            },
            {
              "type": "object",
              "required": [
                "$ref"
              ],
              "properties": {
                "$ref": {
                  "type": "string",
                  "description": "Path to external schema file"
                }
              }
            }
          ]
        },
        "configurationDocs": {
          "type": "object",
          "description": "Documentation for configuration options",
          "additionalProperties": {
            "type": "string"
          }
        },
        "extends": {
          "type": "string",
          "description": "Parent instance type to extend from"
        },
        "metadata": {
          "type": "object",
          "description": "Additional metadata",
          "properties": {
            "author": {
              "type": "string"
            },
            "repository": {
              "type": "string",
              "format": "uri"
            },
            "homepage": {
              "type": "string",
              "format": "uri"
            },
            "license": {
              "type": "string"
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "keywords": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "documentation": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "requirements": {
          "type": "object",
          "description": "Generic requirements declared by this implementation type for scaffolding (runtime-agnostic structure)",
          "properties": {
            "dependencies": {
              "type": "object",
              "description": "Package/library dependencies (structure varies by runtime: npm, pip, cargo, go-mod, etc.)",
              "additionalProperties": true
            },
            "environment": {
              "type": "array",
              "description": "Environment variables and configuration (universal structure)",
              "items": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Environment variable name"
                  },
                  "description": {
                    "type": "string",
                    "description": "Human-readable description"
                  },
                  "example": {
                    "type": "string",
                    "description": "Example value"
                  },
                  "required": {
                    "type": "boolean",
                    "description": "Whether this variable is required"
                  },
                  "category": {
                    "type": "string",
                    "description": "Category for grouping (e.g., 'Database', 'Server', 'Authentication')"
                  }
                },
                "additionalProperties": true
              }
            },
            "configuration": {
              "type": "object",
              "description": "Build/runtime configuration files (structure varies by runtime: tsconfig, pyproject, cargo-toml, etc.)",
              "additionalProperties": true
            },
            "files": {
              "type": "array",
              "description": "Additional files to generate (optional)",
              "items": {
                "type": "object",
                "required": [
                  "path"
                ],
                "properties": {
                  "path": {
                    "type": "string",
                    "description": "File path relative to project root"
                  },
                  "description": {
                    "type": "string",
                    "description": "Description of what this file is for"
                  }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "middleware": {
          "type": "object",
          "description": "Framework-specific middleware configuration",
          "properties": {
            "global": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "preHandler": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "postHandler": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "onResponse": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "onError": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "interceptors": {
          "type": "object",
          "description": "Framework-specific interceptors",
          "properties": {
            "global": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "controller": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "route": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "guards": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Framework-specific guards"
        },
        "pipes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Framework-specific validation pipes"
        },
        "dependencyInjection": {
          "type": "object",
          "description": "DI system configuration",
          "properties": {
            "defaultScope": {
              "type": "string",
              "enum": [
                "singleton",
                "transient",
                "request",
                "session"
              ],
              "default": "singleton"
            },
            "scopeOptions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "lifecycle": {
          "type": "object",
          "description": "Framework-specific lifecycle hook mappings",
          "properties": {
            "mount": {
              "type": "string"
            },
            "unmount": {
              "type": "string"
            },
            "update": {
              "type": "string"
            },
            "beforeUpdate": {
              "type": "string"
            },
            "afterUpdate": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "contentNegotiation": {
          "type": "object",
          "description": "Content type serialization/parsing",
          "properties": {
            "serializers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "contentType": {
                    "type": "string"
                  },
                  "handler": {
                    "type": "string"
                  }
                },
                "required": [
                  "contentType",
                  "handler"
                ],
                "additionalProperties": false
              }
            },
            "parsers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "contentType": {
                    "type": "string"
                  },
                  "handler": {
                    "type": "string"
                  }
                },
                "required": [
                  "contentType",
                  "handler"
                ],
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "eventRouting": {
          "type": "object",
          "description": "Technology-specific event routing",
          "properties": {
            "mechanism": {
              "type": "string",
              "enum": [
                "topic",
                "queue",
                "direct",
                "fanout",
                "partition"
              ]
            },
            "exchangeType": {
              "type": "string"
            },
            "topicStrategy": {
              "type": "string"
            },
            "partitionStrategy": {
              "type": "string",
              "enum": [
                "hash",
                "roundRobin",
                "custom"
              ]
            },
            "routingKeyPattern": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "consumer": {
          "type": "object",
          "description": "Consumer implementation details",
          "properties": {
            "groupIdPattern": {
              "type": "string"
            },
            "queuePattern": {
              "type": "string"
            },
            "autoCommit": {
              "type": "boolean"
            },
            "prefetch": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "deadLetterQueue": {
          "type": "object",
          "description": "DLQ implementation",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "namingPattern": {
              "type": "string"
            },
            "mechanism": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "webhookVerification": {
          "type": "object",
          "description": "Webhook signature verification",
          "properties": {
            "signatureHeader": {
              "type": "string"
            },
            "algorithm": {
              "type": "string",
              "enum": [
                "sha256",
                "sha512",
                "rsa"
              ]
            },
            "verificationMethod": {
              "type": "string",
              "enum": [
                "hmac",
                "rsa",
                "custom"
              ]
            }
          },
          "additionalProperties": false
        },
        "styling": {
          "type": "object",
          "description": "Styling implementation approach",
          "properties": {
            "method": {
              "type": "string",
              "enum": [
                "cssModules",
                "styledComponents",
                "scopedStyles",
                "emotion",
                "tailwind"
              ]
            },
            "fileExtension": {
              "type": "string"
            },
            "classNameStrategy": {
              "type": "string",
              "enum": [
                "camelCase",
                "kebab-case",
                "snake_case"
              ]
            },
            "library": {
              "type": "string"
            },
            "preprocessor": {
              "type": "string",
              "enum": [
                "scss",
                "sass",
                "less",
                "stylus"
              ]
            },
            "scoped": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "migrations": {
          "type": "array",
          "description": "Version migration paths",
          "items": {
            "type": "object",
            "properties": {
              "from": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "breaking": {
                "type": "boolean",
                "default": false
              },
              "migrationSteps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "step": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "automated": {
                      "type": "boolean",
                      "default": false
                    },
                    "command": {
                      "type": "string"
                    },
                    "codemod": {
                      "type": "string"
                    },
                    "documentation": {
                      "type": "string"
                    },
                    "warnings": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  },
                  "required": [
                    "step",
                    "description"
                  ],
                  "additionalProperties": false
                }
              },
              "estimatedDuration": {
                "type": "string"
              },
              "rollbackStrategy": {
                "type": "object",
                "properties": {
                  "automatic": {
                    "type": "boolean",
                    "default": false
                  },
                  "backupRequired": {
                    "type": "boolean",
                    "default": false
                  }
                },
                "additionalProperties": false
              },
              "deprecations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "api": {
                      "type": "string"
                    },
                    "replacement": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "from",
              "to"
            ],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "InstanceFactoryRef": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "peerDependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "version": {
                "type": "string",
                "description": "Semver range"
              },
              "optional": {
                "type": "boolean",
                "default": false
              }
            },
            "required": [
              "name",
              "version"
            ]
          },
          "additionalProperties": false
        }
      },
      "required": [
        "name",
        "source"
      ],
      "additionalProperties": false
    },
    "ViewComponent": {
      "type": "object",
      "description": "Individual UI component within a view",
      "properties": {
        "type": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "table",
                "list",
                "grid",
                "card",
                "chart",
                "tree",
                "timeline",
                "avatar",
                "image",
                "form",
                "input",
                "textarea",
                "select",
                "checkbox",
                "radio",
                "slider",
                "switch",
                "autocomplete",
                "datepicker",
                "timepicker",
                "button",
                "button-group",
                "link",
                "icon",
                "menu",
                "modal",
                "dialog",
                "drawer",
                "popover",
                "tooltip",
                "alert",
                "snackbar",
                "badge",
                "spinner",
                "tabs",
                "breadcrumb",
                "navbar",
                "sidebar",
                "pagination",
                "accordion",
                "carousel",
                "container",
                "divider",
                "header",
                "footer",
                "progress-bar",
                "progress-circle",
                "searchBar",
                "filterPanel"
              ],
              "description": "Standard component types"
            },
            {
              "type": "string",
              "pattern": "^[A-Z][a-zA-Z0-9]*$",
              "description": "Custom component type (PascalCase)"
            },
            {
              "type": "string",
              "pattern": "^[a-z][a-z0-9-]*$",
              "description": "Custom component type (kebab-case)"
            }
          ],
          "description": "Component type identifier"
        },
        "model": {
          "$ref": "#/$defs/TypeReference",
          "description": "Model this component operates on"
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Column names for table/grid components"
        },
        "fields": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  },
                  "type": {
                    "type": "string"
                  },
                  "required": {
                    "type": "boolean"
                  },
                  "placeholder": {
                    "type": "string"
                  }
                },
                "required": [
                  "name"
                ]
              }
            ]
          },
          "description": "Form fields or filter fields"
        },
        "chartType": {
          "type": "string",
          "enum": [
            "pie",
            "bar",
            "line",
            "area",
            "scatter",
            "donut"
          ],
          "description": "Chart type for chart components"
        },
        "dataSource": {
          "type": "string",
          "description": "Data source reference (e.g., 'tasks.status', 'events')"
        },
        "source": {
          "type": "string",
          "description": "Source reference for component data"
        },
        "options": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  }
                },
                "required": [
                  "label",
                  "value"
                ]
              }
            ]
          },
          "description": "Options for select/dropdown components (strings or {label, value} objects)"
        },
        "properties": {
          "type": "object",
          "description": "Component-specific properties",
          "additionalProperties": true
        },
        "events": {
          "type": "object",
          "description": "Event handlers",
          "patternProperties": {
            "^on[A-Z][a-zA-Z0-9]*$": {
              "type": "string",
              "description": "Handler reference (e.g., 'UserController.updateUser')"
            }
          },
          "additionalProperties": false
        },
        "validation": {
          "type": "object",
          "description": "Validation rules for form components",
          "properties": {
            "required": {
              "type": "boolean"
            },
            "pattern": {
              "type": "string"
            },
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            },
            "minLength": {
              "type": "integer"
            },
            "maxLength": {
              "type": "integer"
            }
          }
        }
      },
      "additionalProperties": true
    },
    "StandardLayout": {
      "type": "object",
      "description": "Standard layout patterns",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "single-column",
            "two-column",
            "three-column",
            "grid",
            "flex",
            "sidebar-left",
            "sidebar-right",
            "sidebar-both",
            "header-content",
            "header-content-footer",
            "master-detail",
            "split-horizontal",
            "split-vertical"
          ],
          "description": "Layout pattern type"
        },
        "regions": {
          "type": "object",
          "description": "Named layout regions",
          "patternProperties": {
            "^[a-z][a-zA-Z0-9_]*$": {
              "type": "object",
              "properties": {
                "width": {
                  "type": "string"
                },
                "minWidth": {
                  "type": "string"
                },
                "maxWidth": {
                  "type": "string"
                },
                "height": {
                  "type": "string"
                },
                "minHeight": {
                  "type": "string"
                },
                "maxHeight": {
                  "type": "string"
                },
                "flex": {
                  "type": "string"
                },
                "order": {
                  "type": "integer"
                },
                "align": {
                  "type": "string",
                  "enum": [
                    "start",
                    "center",
                    "end",
                    "stretch"
                  ]
                }
              }
            }
          }
        },
        "spacing": {
          "type": "string",
          "description": "Gap between regions"
        },
        "responsive": {
          "type": "object",
          "description": "Responsive breakpoint overrides",
          "properties": {
            "mobile": {
              "type": "object"
            },
            "tablet": {
              "type": "object"
            },
            "desktop": {
              "type": "object"
            }
          }
        }
      },
      "additionalProperties": true
    },
    "ViewProperties": {
      "type": "object",
      "description": "View-level feature flags and configuration",
      "properties": {
        "responsive": {
          "type": "boolean"
        },
        "authenticated": {
          "type": "boolean"
        },
        "authorized": {
          "type": "boolean"
        },
        "realtime": {
          "type": "boolean"
        },
        "sortable": {
          "type": "boolean"
        },
        "filterable": {
          "type": "boolean"
        },
        "searchable": {
          "type": "boolean"
        },
        "paginated": {
          "type": "boolean"
        },
        "pagination": {
          "type": "boolean"
        },
        "exportable": {
          "type": "boolean"
        },
        "printable": {
          "type": "boolean"
        },
        "bookmarkable": {
          "type": "boolean"
        },
        "cacheable": {
          "type": "boolean"
        },
        "editable": {
          "type": "boolean"
        },
        "refreshInterval": {
          "type": "integer",
          "description": "Auto-refresh interval in milliseconds"
        },
        "theme": {
          "type": "string",
          "enum": [
            "light",
            "dark",
            "auto",
            "system"
          ]
        },
        "locale": {
          "type": "string",
          "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
        }
      },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "boolean"
          },
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "array"
          },
          {
            "type": "object"
          }
        ]
      }
    },
    "OperationPolicies": {
      "type": "object",
      "description": "Deployment-specific operational policies for an operation",
      "properties": {
        "transactional": {
          "type": "object",
          "description": "Transaction management configuration",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "isolation": {
              "type": "string",
              "enum": [
                "READ_UNCOMMITTED",
                "READ_COMMITTED",
                "REPEATABLE_READ",
                "SERIALIZABLE"
              ],
              "default": "READ_COMMITTED",
              "description": "Transaction isolation level"
            },
            "propagation": {
              "type": "string",
              "enum": [
                "REQUIRED",
                "REQUIRES_NEW",
                "SUPPORTS",
                "NOT_SUPPORTED",
                "MANDATORY",
                "NEVER"
              ],
              "default": "REQUIRED",
              "description": "Transaction propagation behavior"
            },
            "timeout": {
              "type": "integer",
              "minimum": 1,
              "description": "Transaction timeout in seconds"
            },
            "readOnly": {
              "type": "boolean",
              "default": false,
              "description": "Mark transaction as read-only for optimization"
            }
          },
          "additionalProperties": false
        },
        "retry": {
          "$ref": "#/$defs/RetryPolicy"
        },
        "circuitBreaker": {
          "$ref": "#/$defs/CircuitBreakerPolicy"
        },
        "idempotency": {
          "type": "object",
          "description": "Idempotency enforcement",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "keyField": {
              "type": "string",
              "description": "Parameter field to use as idempotency key"
            },
            "ttlSeconds": {
              "type": "integer",
              "minimum": 1,
              "description": "How long to remember idempotency keys"
            }
          },
          "additionalProperties": false
        },
        "cache": {
          "type": "object",
          "description": "Operation-level caching",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "ttlSeconds": {
              "type": "integer",
              "minimum": 1,
              "description": "Cache TTL in seconds"
            },
            "keyFields": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Parameter fields to include in cache key"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "RateLimitPolicy": {
      "type": "object",
      "description": "Rate limiting configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "requestsPerMinute": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum requests per minute"
        },
        "burstSize": {
          "type": "integer",
          "minimum": 1,
          "description": "Burst allowance above rate limit"
        },
        "byIP": {
          "type": "boolean",
          "default": true,
          "description": "Apply limit per IP address"
        },
        "byUser": {
          "type": "boolean",
          "default": false,
          "description": "Apply limit per authenticated user"
        },
        "byApiKey": {
          "type": "boolean",
          "default": false,
          "description": "Apply limit per API key"
        }
      },
      "additionalProperties": false
    },
    "RetryPolicy": {
      "type": "object",
      "description": "Retry policy configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "maxAttempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 3,
          "description": "Maximum retry attempts"
        },
        "backoffMs": {
          "type": "integer",
          "minimum": 100,
          "description": "Initial backoff delay in milliseconds"
        },
        "backoffMultiplier": {
          "type": "number",
          "minimum": 1,
          "default": 2,
          "description": "Exponential backoff multiplier"
        },
        "maxBackoffMs": {
          "type": "integer",
          "minimum": 100,
          "description": "Maximum backoff delay"
        },
        "retryableErrors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Error types/codes that should trigger retry"
        }
      },
      "additionalProperties": false
    },
    "CircuitBreakerPolicy": {
      "type": "object",
      "description": "Circuit breaker policy configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1,
          "default": 5,
          "description": "Number of failures before opening circuit"
        },
        "successThreshold": {
          "type": "integer",
          "minimum": 1,
          "default": 2,
          "description": "Number of successes before closing circuit"
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 100,
          "description": "Operation timeout before considering it a failure"
        },
        "halfOpenAfterMs": {
          "type": "integer",
          "minimum": 1000,
          "default": 60000,
          "description": "Time to wait before attempting half-open state"
        }
      },
      "additionalProperties": false
    },
    "ResourceConfiguration": {
      "type": "object",
      "description": "Resource requests and limits",
      "properties": {
        "requests": {
          "type": "object",
          "description": "Guaranteed resource allocation",
          "properties": {
            "cpu": {
              "type": "string",
              "pattern": "^[0-9]+(m|[0-9]*\\.?[0-9]+)?$",
              "description": "CPU request (e.g., 100m, 0.5, 1)"
            },
            "memory": {
              "type": "string",
              "pattern": "^[0-9]+([KMGT]i?)?$",
              "description": "Memory request (e.g., 128Mi, 1Gi)"
            },
            "ephemeralStorage": {
              "type": "string",
              "pattern": "^[0-9]+([KMGT]i?)?$",
              "description": "Ephemeral storage request"
            }
          },
          "additionalProperties": false
        },
        "limits": {
          "type": "object",
          "description": "Maximum resource allocation",
          "properties": {
            "cpu": {
              "type": "string",
              "pattern": "^[0-9]+(m|[0-9]*\\.?[0-9]+)?$",
              "description": "CPU limit"
            },
            "memory": {
              "type": "string",
              "pattern": "^[0-9]+([KMGT]i?)?$",
              "description": "Memory limit"
            },
            "ephemeralStorage": {
              "type": "string",
              "pattern": "^[0-9]+([KMGT]i?)?$",
              "description": "Ephemeral storage limit"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "AutoscalingConfiguration": {
      "type": "object",
      "description": "Horizontal pod autoscaling configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 1,
          "default": 1,
          "description": "Minimum number of replicas"
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1,
          "default": 10,
          "description": "Maximum number of replicas"
        },
        "targetCPU": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "description": "Target CPU utilization percentage"
        },
        "targetMemory": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "description": "Target memory utilization percentage"
        },
        "customMetrics": {
          "type": "array",
          "description": "Custom metrics for scaling",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "pods",
                  "object",
                  "external"
                ]
              },
              "target": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "Utilization",
                      "Value",
                      "AverageValue"
                    ]
                  },
                  "averageValue": {
                    "type": "string"
                  },
                  "value": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "scaleDown": {
          "type": "object",
          "description": "Scale down behavior",
          "properties": {
            "stabilizationWindowSeconds": {
              "type": "integer",
              "minimum": 0,
              "default": 300,
              "description": "Cooldown period before scaling down"
            },
            "selectPolicy": {
              "type": "string",
              "enum": [
                "Max",
                "Min",
                "Disabled"
              ],
              "default": "Max"
            }
          },
          "additionalProperties": false
        },
        "scaleUp": {
          "type": "object",
          "description": "Scale up behavior",
          "properties": {
            "stabilizationWindowSeconds": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "selectPolicy": {
              "type": "string",
              "enum": [
                "Max",
                "Min",
                "Disabled"
              ],
              "default": "Max"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
