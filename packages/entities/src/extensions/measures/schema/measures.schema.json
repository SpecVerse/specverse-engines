{
  "$id": "specverse://entities/measures",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Measure-specific schema definitions for analytics and aggregation specifications",
  "$defs": {
    "MeasuresSection": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-zA-Z0-9_]*$": {
          "type": "object",
          "properties": {
            "description": { "type": "string" },
            "source": { "type": "string" },
            "aggregation": {
              "type": "string",
              "enum": ["sum", "count", "avg", "min", "max", "custom"]
            },
            "field": { "type": "string" },
            "computation": { "type": "string" },
            "filter": { "type": "string" },
            "dimensions": {
              "type": "array",
              "items": { "type": "string" }
            },
            "format": { "type": "string" }
          },
          "required": ["source", "aggregation"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
