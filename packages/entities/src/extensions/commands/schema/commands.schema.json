{
  "$id": "specverse://entities/commands",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Command-specific schema definitions for CLI interface specifications",
  "$defs": {
    "CommandsSection": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-zA-Z0-9_-]*$": {
          "type": "object",
          "properties": {
            "description": { "type": "string" },
            "arguments": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "type": { "type": "string" },
                  "required": { "type": "boolean" },
                  "positional": { "type": "boolean" },
                  "description": { "type": "string" },
                  "default": {}
                }
              }
            },
            "flags": {
              "type": "object",
              "patternProperties": {
                "^--[a-z][a-zA-Z0-9-]*$": {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string" },
                    "default": {},
                    "description": { "type": "string" },
                    "alias": { "type": "string" }
                  }
                }
              }
            },
            "returns": { "type": "string" },
            "exitCodes": {
              "type": "object",
              "patternProperties": {
                "^[0-9]+$": { "type": "string" }
              }
            },
            "subcommands": {
              "type": "object",
              "additionalProperties": { "type": "object" }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
