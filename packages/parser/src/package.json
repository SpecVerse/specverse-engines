{
  "name": "@specverse/v3-parser",
  "version": "3.3.0",
  "description": "SpecVerse v3.0 YAML + Conventions Parser",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  
  "scripts": {
    "build": "echo 'Parser is built via root npm run build'",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "echo 'Use root npm run clean'"
  },
  
  "dependencies": {
    "js-yaml": "^4.1.0",
    "ajv": "^8.12.0",
    "ajv-draft-04": "^1.0.0",
    "ajv-formats": "^2.1.1"
  },
  
  "devDependencies": {
    "@types/js-yaml": "^4.0.8",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  
  "keywords": [
    "specverse",
    "yaml",
    "conventions",
    "parser",
    "ast",
    "specification"
